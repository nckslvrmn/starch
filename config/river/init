#!/bin/bash
# River 0.4 init — launches the window manager and autostart programs.
#
# River 0.4 split the compositor and window manager into separate processes.
# The compositor (river) handles rendering/KMS; all keybindings, tiling, and
# focus policy live in the window manager (river-pwm for us).
#
# Display configuration (wlr-randr) is handled inside pwm.py or can be done
# here before the WM starts if needed.

STARCH_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/river"

# ---------------------------------------------------------------------------
# Display configuration via wlr-randr
#
# River 0.4 still exposes wlr-randr, so we configure outputs here before
# the WM starts laying out windows.
# ---------------------------------------------------------------------------

_configure_displays() {
    if ! command -v wlr-randr >/dev/null 2>&1 || ! command -v jq >/dev/null 2>&1; then
        echo "[river/init] wlr-randr or jq not found — skipping display configuration"
        return
    fi

    # Give the compositor a moment to enumerate outputs
    sleep 0.5

    local wlr_json
    wlr_json=$(wlr-randr --json 2>/dev/null) || {
        echo "[river/init] wlr-randr failed — skipping display configuration"
        return
    }

    local primary="${STARCH_PRIMARY_OUTPUT:-}"
    local cursor_x=0

    _apply_output() {
        local name="$1" width="$2" height="$3" refresh_mhz="$4"
        local refresh_hz
        if [ "$refresh_mhz" -gt 1000 ] 2>/dev/null; then
            refresh_hz=$(( refresh_mhz / 1000 ))
        else
            refresh_hz="$refresh_mhz"
        fi

        local scale="1"
        if [ "$height" -ge 2160 ]; then
            scale="2"
        elif [ "$height" -ge 1440 ]; then
            scale="1.5"
        fi

        echo "[river/init] enabling $name @ ${width}x${height}@${refresh_hz}Hz scale=${scale} pos=${cursor_x},0"
        wlr-randr --output "$name" --on \
            --mode "${width}x${height}@${refresh_hz}" \
            --scale "$scale" \
            --pos "${cursor_x},0"

        cursor_x=$(( cursor_x + width * 10 / $(awk -v s="$scale" 'BEGIN{print int(s*10)}') ))
    }

    # Two passes: primary first, then the rest.
    local name width height refresh_mhz
    if [ -n "$primary" ]; then
        while IFS=$'\t' read -r name width height refresh_mhz; do
            [ "$name" = "$primary" ] || continue
            _apply_output "$name" "$width" "$height" "$refresh_mhz"
        done < <(echo "$wlr_json" | jq -r '
            .[] |
            (.modes | max_by(.refresh)) as $m |
            [.name,
             ($m.width  | tostring),
             ($m.height | tostring),
             ($m.refresh | tostring)] | @tsv
        ')
    fi

    while IFS=$'\t' read -r name width height refresh_mhz; do
        [ "$name" = "$primary" ] && continue
        _apply_output "$name" "$width" "$height" "$refresh_mhz"
    done < <(echo "$wlr_json" | jq -r '
        .[] |
        (.modes | max_by(.refresh)) as $m |
        [.name,
         ($m.width  | tostring),
         ($m.height | tostring),
         ($m.refresh | tostring)] | @tsv
    ')
}

_configure_displays &

# ---------------------------------------------------------------------------
# Media key daemons (volume / brightness)
#
# river-pwm handles keybindings registered via its protocol, but media keys
# are simpler to wire up here via a small background helper since they just
# spawn shell commands and don't need window-management state.
# ---------------------------------------------------------------------------

_media_keys_via_wev() {
    # If river-pwm gains raw-keybinding support for media keys, remove this.
    # For now we rely on the WM's custom_keybindings being sufficient.
    # Media keys are handled via custom bindings if the WM supports them,
    # otherwise users can run something like `swhkd` or `wev` here.
    true
}

# ---------------------------------------------------------------------------
# Window manager — river-pwm
# ---------------------------------------------------------------------------

echo "[river/init] starting river-pwm"
python3 "$STARCH_DIR/pwm.py" &
PWM_PID=$!

# ---------------------------------------------------------------------------
# Autostart
# ---------------------------------------------------------------------------

sleep 1  # Let the WM initialize before spawning windows
/usr/bin/ghostty &

# Wait for the WM to exit (River stays alive; Ctrl+Alt+Delete exits river)
wait $PWM_PID
