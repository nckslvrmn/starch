#!/bin/bash
# start-steam — gamescope + Steam session launcher
# Deploy: sudo install -Dm755 scripts/start-steam /usr/local/bin/start-steam
# Log:    ~/.local/share/steam-session.log
set -uo pipefail

# shellcheck source=./starch-profile.sh
. /usr/local/lib/starch/profile.sh

starch_profile_init
starch_session_begin steam
starch_check_gpu_modules steam-session
starch_apply_gpu_env

# Proton / Steam runtime tuning
export PROTON_ENABLE_NVAPI=1
export DXVK_ASYNC=1
export STEAM_RUNTIME_HEAVY=1
export SDL_JOYSTICK_HIDAPI_GAMECUBE=0
export STEAM_GAMESCOPE_SESSION=1

# Wait for WirePlumber to bind a real default sink (see starch-profile.sh).
starch_wait_for_audio steam-session

# Launch — when gamescope exits, the session ends and SDDM takes over.
#
# --prefer-output pins scanout to the connector the user chose. Gamescope
# auto-detects the connector's highest refresh mode, so no manual modetest
# probe is needed. HDR scanout is only viable end-to-end on the nvidia
# profile; Intel (optimus) and Mesa HDR pipelines don't round-trip cleanly.

GAMESCOPE_ARGS=(--backend drm --steam -f --rt --adaptive-sync)
[ "$STARCH_PROFILE" = "nvidia" ] && GAMESCOPE_ARGS+=(--hdr-enabled)
[ -n "${STARCH_PRIMARY_OUTPUT:-}" ] && GAMESCOPE_ARGS+=(--prefer-output "$STARCH_PRIMARY_OUTPUT")

if [ "$STARCH_PROFILE" = "optimus" ]; then
    # Gamescope's Vulkan device must match its KMS device, otherwise buffer
    # modifiers are incompatible → drmModeAddFB2WithModifiers: invalid argument.
    #
    # Which GPU does KMS depends on the selected output:
    #   eDP (Intel)  → --prefer-vk-device 8086 (Intel ANV)
    #   HDMI (NVIDIA) → --prefer-vk-device 10de (NVIDIA)
    if [ "${STARCH_OUTPUT_CARD:-}" = "$STARCH_NVIDIA_CARD" ]; then
        GAMESCOPE_ARGS+=(--prefer-vk-device 10de)
        echo "[steam-session] optimus: HDMI on NVIDIA → NVIDIA Vulkan + KMS"
    else
        GAMESCOPE_ARGS+=(--prefer-vk-device 8086)
        echo "[steam-session] optimus: eDP on Intel → Intel Vulkan + KMS"
    fi
fi

# On optimus the compositor (gamescope) runs on the Intel iGPU for KMS;
# Steam and its games need PRIME offload env to render on the NVIDIA dGPU.
mapfile -t PRIME_ENV < <(starch_prime_env env)

echo "[steam-session] gamescope ${GAMESCOPE_ARGS[*]}"
if [ ${#PRIME_ENV[@]} -gt 0 ]; then
    exec gamescope "${GAMESCOPE_ARGS[@]}" -- env "${PRIME_ENV[@]}" steam -gamepadui
else
    exec gamescope "${GAMESCOPE_ARGS[@]}" -- steam -gamepadui
fi
