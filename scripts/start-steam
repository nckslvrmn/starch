#!/bin/bash
# start-steam — gamescope + Steam session launcher
# Deploy: sudo install -Dm755 scripts/start-steam /usr/local/bin/start-steam
# Log:    ~/.local/share/steam-session.log
set -uo pipefail

LOGFILE="$HOME/.local/share/steam-session.log"
mkdir -p "$(dirname "$LOGFILE")"
exec > >(tee -a "$LOGFILE") 2>&1

echo "[steam-session] START $(date '+%Y-%m-%d %H:%M:%S')"

# ---------------------------------------------------------------------------
# GPU detection
# ---------------------------------------------------------------------------

GPU_VENDOR="unknown"
DRM_DEVICE="/dev/dri/card1"
for card in /sys/class/drm/card[0-9]; do
    vendor=$(cat "$card/device/vendor" 2>/dev/null) || continue
    case "$vendor" in
        0x10de) GPU_VENDOR="nvidia"; DRM_DEVICE="/dev/dri/$(basename "$card")"; break ;;
        0x1002) GPU_VENDOR="amd";    DRM_DEVICE="/dev/dri/$(basename "$card")"; break ;;
    esac
done

echo "[steam-session] GPU: $GPU_VENDOR  device: $DRM_DEVICE"

# ---------------------------------------------------------------------------
# Refresh rate — highest mode across all connected connectors
# ---------------------------------------------------------------------------

REFRESH=0
DRM_MODULE=""
case "$GPU_VENDOR" in
    nvidia) DRM_MODULE="nvidia-drm" ;;
    amd)    DRM_MODULE="amdgpu" ;;
esac

if [ -n "$DRM_MODULE" ] && command -v modetest &>/dev/null; then
    REFRESH=$(modetest -M "$DRM_MODULE" 2>/dev/null | awk '
        $3 == "connected"                              { in_conn = 1; next }
        in_conn && /^[0-9]/                            { in_conn = 0 }
        in_conn && /^[[:space:]]+#/ && $3+0 > max     { max = $3+0 }
        END { if (max) printf "%d\n", max }
    ')
    REFRESH="${REFRESH:-0}"
fi

echo "[steam-session] Refresh: ${REFRESH}Hz"

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------

export WLR_DRM_DEVICES="$DRM_DEVICE"

case "$GPU_VENDOR" in
    nvidia)
        export GBM_BACKEND=nvidia-drm
        export __GLX_VENDOR_LIBRARY_NAME=nvidia
        export __EGL_VENDOR_LIBRARY_FILENAMES=/usr/share/glvnd/egl_vendor.d/10_nvidia.json
        export LIBVA_DRIVER_NAME=nvidia
        export NVD_BACKEND=direct
        export WLR_NO_HARDWARE_CURSORS=1
        export ENABLE_IMPLICIT_SYNC=1
        export PROTON_ENABLE_NVAPI=1
        ;;
    amd)
        export LIBVA_DRIVER_NAME=radeonsi
        ;;
esac

export DXVK_ASYNC=1
export STEAM_RUNTIME_HEAVY=1
export SDL_JOYSTICK_HIDAPI_GAMECUBE=0
export STEAM_GAMESCOPE_SESSION=1

# ---------------------------------------------------------------------------
# Wait for PipeWire + WirePlumber — SDDM starts the systemd user session but
# audio services may still be initializing.  Without this, gamescope can grab
# a half-ready audio node that later gets reassigned, killing in-game sound.
# ---------------------------------------------------------------------------

for i in $(seq 1 50); do
    if pw-cli info 0 &>/dev/null && wpctl status &>/dev/null; then
        echo "[steam-session] PipeWire ready after ~$((i * 100))ms"
        break
    fi
    sleep 0.1
done

# ---------------------------------------------------------------------------
# Launch — after gamescope exits, fall back to the river desktop session.
# ---------------------------------------------------------------------------

GAMESCOPE_ARGS=(--backend drm --steam -f --rt --hdr-enabled)
[ "$REFRESH" != "0" ] && GAMESCOPE_ARGS+=(-r "$REFRESH")

echo "[steam-session] gamescope ${GAMESCOPE_ARGS[*]}"
gamescope "${GAMESCOPE_ARGS[@]}" -- steam -gamepadui

# When gamescope exits (Switch to Desktop, Steam exit, or crash), hand off to
# the river desktop session.  Return to SDDM from river via Super+Shift+E.
echo "[steam-session] gamescope exited, switching to desktop $(date '+%Y-%m-%d %H:%M:%S')"
exec /usr/local/bin/start-river
