#!/bin/bash
set -euo pipefail

CONF_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/starch"
CONF_FILE="$CONF_DIR/display.conf"
SDDM_WESTON_INI="/etc/sddm/weston.ini"

INTERNAL_RE='^(eDP|LVDS|DSI)(-|$)'

list_connected_outputs() {
    local f name
    for f in /sys/class/drm/card*-*/status; do
        [ -r "$f" ] || continue
        [ "$(cat "$f")" = "connected" ] || continue
        name="${f%/status}"
        name="${name##*/}"
        name="${name#card*-}"
        echo "$name"
    done
}

render_weston_ini() {
    local choice="$1" name disable
    cat <<'EOF'
# Managed by starch-select-display. Do not edit by hand.
# Used by the SDDM Wayland greeter (weston --shell=kiosk).
EOF
    echo "# Mode: $choice"
    echo
    while read -r name; do
        [ -n "$name" ] || continue
        disable=0
        case "$choice" in
            internal) [[ "$name" =~ $INTERNAL_RE ]] || disable=1 ;;
            external) [[ "$name" =~ $INTERNAL_RE ]] && disable=1 ;;
            auto) ;;
        esac
        [ "$disable" = "1" ] || continue
        printf '[output]\nname=%s\nmode=off\n\n' "$name"
    done < <(list_connected_outputs)
}

apply_sddm() {
    local choice="$1" tmp
    tmp="$(mktemp)"
    render_weston_ini "$choice" > "$tmp"
    if [ "$(id -u)" -eq 0 ]; then
        install -Dm644 "$tmp" "$SDDM_WESTON_INI"
    elif command -v sudo >/dev/null 2>&1; then
        sudo install -Dm644 "$tmp" "$SDDM_WESTON_INI"
    else
        echo "starch: cannot write $SDDM_WESTON_INI without root; skipping SDDM update" >&2
        rm -f "$tmp"
        return 0
    fi
    rm -f "$tmp"
    echo "starch: SDDM greeter outputs updated ($SDDM_WESTON_INI)"
}

usage() {
    cat <<'EOF'
starch-select-display — pick which output should be the primary display.

Usage:
  starch-select-display                 interactive whiptail menu
  starch-select-display auto|internal|external
  starch-select-display --show          print current preference

Values:
  auto      prefer external (HDMI/DP) if connected, else internal eDP
  internal  always use the internal laptop panel
  external  always use the first connected external output,
            falling back to internal if nothing is plugged in
EOF
}

current() {
    [ -r "$CONF_FILE" ] || { echo "auto"; return; }
    ( . "$CONF_FILE"; echo "${PRIMARY:-auto}" )
}

save() {
    local choice="$1"
    case "$choice" in
        auto|internal|external) ;;
        *) echo "error: invalid choice '$choice' (expected auto|internal|external)" >&2; exit 1 ;;
    esac
    mkdir -p "$CONF_DIR"
    umask 077
    cat > "$CONF_FILE" <<EOF
PRIMARY=$choice
EOF
    echo "starch: primary display preference set to '$choice'"
    apply_sddm "$choice"
}

if [ $# -gt 0 ]; then
    case "$1" in
        --show|-s) current; exit 0 ;;
        auto|internal|external) save "$1"; exit 0 ;;
        -h|--help) usage; exit 0 ;;
        *) echo "unknown argument: $1" >&2; exit 1 ;;
    esac
fi

if ! command -v whiptail >/dev/null 2>&1; then
    echo "whiptail not found; pass the choice as an argument instead." >&2
    echo "  starch-select-display auto|internal|external" >&2
    exit 1
fi

cur="$(current)"
choice=$(whiptail --title "starch — primary display" \
    --default-item "$cur" \
    --menu "Which display should sessions render to by default?" 15 60 3 \
    "auto"     "Prefer external when connected, else internal" \
    "internal" "Always the internal laptop panel (eDP)" \
    "external" "Always an external display (HDMI/DP)" \
    3>&1 1>&2 2>&3)
save "$choice"
