#!/bin/bash
# start-river — River Wayland compositor session launcher
set -uo pipefail

# shellcheck source=./starch-profile.sh
. /usr/local/lib/starch/profile.sh
starch_profile_init

export XDG_CURRENT_DESKTOP=river
export MOZ_ENABLE_WAYLAND=1
export SDL_VIDEODRIVER=wayland

# HiDPI / Wayland-native app support
export XCURSOR_SIZE=32
export QT_AUTO_SCREEN_SCALE_FACTOR=1
export ELECTRON_OZONE_PLATFORM_HINT=auto

starch_apply_gpu_env

# Wait for WirePlumber to bind a real default sink so the media-key bindings
# configured in config/river/init have something to target.
starch_wait_for_audio river-session

exec river
