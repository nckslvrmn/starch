#!/bin/bash
set -u

case "${1:-}" in
    desktop|gamescope) ;;
    ""|-h|--help)
        echo "Usage: steamos-session-select {desktop|gamescope}"
        exit 1
        ;;
    *)
        echo "steamos-session-select: unknown target '$1' (expected desktop|gamescope)" >&2
        exit 1
        ;;
esac

if ! pgrep -x gamescope >/dev/null 2>&1; then
    echo "steamos-session-select: gamescope is not running — nothing to switch from." >&2
    echo "  Log out via your current session instead, then pick one at the SDDM greeter." >&2
    exit 2
fi

_wait_gone() {
    local target="$1" max="${2:-80}" i
    for i in $(seq 1 "$max"); do
        pgrep -x "$target" >/dev/null 2>&1 || return 0
        sleep 0.1
    done
    return 1
}

# gamescope was started with --steam, so it exits when its Steam client
# exits. Asking Steam to quit cleanly is what actually unwinds the whole
# session (steam → gamescope → dbus-run-session → start-steam) back to SDDM.
# Just SIGTERMing gamescope first hangs because gamescope waits on Steam.
steam -shutdown >/dev/null 2>&1 || true
_wait_gone gamescope 200 && exit 0

# Steam ignored the shutdown request — tear gamescope down directly.
pkill -TERM -x gamescope 2>/dev/null || true
_wait_gone gamescope 100 && exit 0

# Last resort. After SIGKILL, ask SDDM to restart so the next greeter
# starts from a known-clean state (gamescope-killed-mid-DRM-handoff
# can otherwise leave the GPU stuck and the greeter black).
pkill -KILL -x gamescope 2>/dev/null || true
pkill -KILL -x steam 2>/dev/null || true
sleep 1
if command -v systemctl >/dev/null 2>&1; then
    systemctl restart sddm.service 2>/dev/null || true
fi
