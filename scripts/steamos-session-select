#!/bin/bash
# steamos-session-select — switch between Steam (gamescope) and Desktop (river)
#
# Steam's "Switch to Desktop" power-menu entry calls:
#   steamos-session-select desktop
#
# From the river desktop, return to Steam via:
#   steamos-session-select gamescope   (or just exit river → SDDM → pick Steam)

case "${1:-}" in
  desktop)
    # Shut down Steam gracefully — gamescope exits when its child (steam) does,
    # then start-steam falls through to start-river.
    steam -shutdown 2>/dev/null || pkill -TERM -f 'steam.*-gamepadui'
    ;;
  gamescope)
    # Kill river — session ends, SDDM login screen takes over
    pkill -TERM -x river 2>/dev/null
    ;;
  *)
    echo "Usage: steamos-session-select {desktop|gamescope}"
    exit 1
    ;;
esac
