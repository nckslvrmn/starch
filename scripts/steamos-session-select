#!/bin/bash
# steamos-session-select — switch sessions by killing gamescope and returning to SDDM
#
# Steam's "Switch to Desktop" power-menu entry calls:
#   steamos-session-select desktop
#
# From the river desktop, return to Steam via:
#   steamos-session-select gamescope

case "${1:-}" in
    desktop|gamescope)
        # Kill gamescope — the session process (start-steam/start-plex) exits,
        # and SDDM takes back control of the display.
        pkill -TERM -x gamescope 2>/dev/null
        ;;
    *)
        echo "Usage: steamos-session-select {desktop|gamescope}"
        exit 1
        ;;
esac
