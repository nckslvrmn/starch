#!/bin/bash
# steamos-session-select — session switcher used by Steam's power menu.
#
# Steam's "Switch to Desktop" entry runs:
#   steamos-session-select desktop
#
# Both subcommands do the same thing: kill gamescope so the current session
# script (start-steam / start-plex) exits and SDDM regains the display. The
# user then picks a session from the SDDM greeter.
#
# We refuse to run if gamescope isn't actually up — calling this from the
# river desktop, or after gamescope already crashed, would otherwise silently
# succeed and mask the real problem.

set -u

case "${1:-}" in
    desktop|gamescope) ;;
    ""|-h|--help)
        echo "Usage: steamos-session-select {desktop|gamescope}"
        exit 1
        ;;
    *)
        echo "steamos-session-select: unknown target '$1' (expected desktop|gamescope)" >&2
        exit 1
        ;;
esac

if ! pgrep -x gamescope >/dev/null 2>&1; then
    echo "steamos-session-select: gamescope is not running — nothing to switch from." >&2
    echo "  Log out via your current session instead, then pick one at the SDDM greeter." >&2
    exit 2
fi

pkill -TERM -x gamescope
