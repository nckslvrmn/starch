#!/bin/bash
# start-plex — Plex HTPC session via gamescope (adaptive sync for judder-free video)
# Deploy: sudo install -Dm755 scripts/start-plex /usr/local/bin/start-plex
# Log:    ~/.local/share/plex-session.log
set -uo pipefail

LOGFILE="$HOME/.local/share/plex-session.log"
mkdir -p "$(dirname "$LOGFILE")"
exec > >(tee -a "$LOGFILE") 2>&1

echo "[plex-session] START $(date '+%Y-%m-%d %H:%M:%S')"

# ---------------------------------------------------------------------------
# Find the NVIDIA DRM device
# ---------------------------------------------------------------------------

DRM_DEVICE="/dev/dri/card1"
for card in /sys/class/drm/card[0-9]; do
    vendor=$(cat "$card/device/vendor" 2>/dev/null) || continue
    if [ "$vendor" = "0x10de" ]; then
        DRM_DEVICE="/dev/dri/$(basename "$card")"
        break
    fi
done

echo "[plex-session] device: $DRM_DEVICE"

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------

export WLR_DRM_DEVICES="$DRM_DEVICE"
export GBM_BACKEND=nvidia-drm
export __GLX_VENDOR_LIBRARY_NAME=nvidia
export __EGL_VENDOR_LIBRARY_FILENAMES=/usr/share/glvnd/egl_vendor.d/10_nvidia.json
export LIBVA_DRIVER_NAME=nvidia
export NVD_BACKEND=direct
export WLR_NO_HARDWARE_CURSORS=1
export ENABLE_IMPLICIT_SYNC=1

# ---------------------------------------------------------------------------
# Wait for a real default audio sink — not just the PipeWire daemon.
# ---------------------------------------------------------------------------

systemctl --user start pipewire.service pipewire-pulse.service wireplumber.service 2>/dev/null || true

for i in $(seq 1 100); do
    if wpctl get-volume @DEFAULT_AUDIO_SINK@ &>/dev/null; then
        echo "[plex-session] Default audio sink ready after ~$((i * 100))ms"
        break
    fi
    sleep 0.1
done

if ! wpctl get-volume @DEFAULT_AUDIO_SINK@ &>/dev/null; then
    echo "[plex-session] WARNING: no default audio sink after 10s — launching anyway"
fi

# ---------------------------------------------------------------------------
# Launch — gamescope with adaptive sync for judder-free video playback.
# VRR lets gamescope present frames at the content's native cadence
# (24fps, 30fps, etc.) instead of pulling down to a fixed refresh rate.
# When Plex exits, gamescope exits, and SDDM takes over.
# ---------------------------------------------------------------------------

echo "[plex-session] launching gamescope"
gamescope --backend drm -f --hdr-enabled --adaptive-sync -- \
    flatpak run --device=dri \
    --env=LIBVA_DRIVER_NAME=nvidia \
    --env=NVD_BACKEND=direct \
    --env=__GLX_VENDOR_LIBRARY_NAME=nvidia \
    --env=GBM_BACKEND=nvidia-drm \
    tv.plex.PlexHTPC

echo "[plex-session] END $(date '+%Y-%m-%d %H:%M:%S')"
