#!/bin/bash
# start-plex — Plex HTPC kiosk session via cage
# Deploy: sudo install -Dm755 scripts/start-plex /usr/local/bin/start-plex
# Log:    ~/.local/share/plex-session.log
set -uo pipefail

LOGFILE="$HOME/.local/share/plex-session.log"
mkdir -p "$(dirname "$LOGFILE")"
exec > >(tee -a "$LOGFILE") 2>&1

echo "[plex-session] START $(date '+%Y-%m-%d %H:%M:%S')"

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------

export GBM_BACKEND=nvidia-drm
export __GLX_VENDOR_LIBRARY_NAME=nvidia
export __EGL_VENDOR_LIBRARY_FILENAMES=/usr/share/glvnd/egl_vendor.d/10_nvidia.json
export LIBVA_DRIVER_NAME=nvidia
export NVD_BACKEND=direct
export WLR_NO_HARDWARE_CURSORS=1
export ENABLE_IMPLICIT_SYNC=1

# ---------------------------------------------------------------------------
# Wait for PipeWire + WirePlumber
# ---------------------------------------------------------------------------

for i in $(seq 1 50); do
    if pw-cli info 0 &>/dev/null && wpctl status &>/dev/null; then
        echo "[plex-session] PipeWire ready after ~$((i * 100))ms"
        break
    fi
    sleep 0.1
done

# ---------------------------------------------------------------------------
# Launch — cage runs Plex fullscreen as the sole Wayland client.
# When Plex exits, cage exits, and SDDM takes over.
# ---------------------------------------------------------------------------

echo "[plex-session] launching cage"
cage -- flatpak run --device=dri \
    --env=LIBVA_DRIVER_NAME=nvidia \
    --env=NVD_BACKEND=direct \
    --env=__GLX_VENDOR_LIBRARY_NAME=nvidia \
    --env=GBM_BACKEND=nvidia-drm \
    tv.plex.PlexHTPC

echo "[plex-session] END $(date '+%Y-%m-%d %H:%M:%S')"
