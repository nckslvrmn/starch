#!/bin/bash
# start-plex — Plex HTPC session via gamescope (adaptive sync for judder-free video)
# Deploy: sudo install -Dm755 scripts/start-plex /usr/local/bin/start-plex
# Log:    ~/.local/share/plex-session.log
set -uo pipefail

LOGFILE="$HOME/.local/share/plex-session.log"
mkdir -p "$(dirname "$LOGFILE")"
exec > >(tee -a "$LOGFILE") 2>&1

echo "[plex-session] START $(date '+%Y-%m-%d %H:%M:%S')"

# ---------------------------------------------------------------------------
# Hardware profile + display preference
# ---------------------------------------------------------------------------

# shellcheck source=./starch-profile.sh
. /usr/local/lib/starch/profile.sh
starch_profile_init

echo "[plex-session] profile:        $STARCH_PROFILE"
echo "[plex-session] display device: $STARCH_DISPLAY_CARD"
echo "[plex-session] render device:  $STARCH_RENDER_CARD"
echo "[plex-session] primary pref:   $STARCH_PRIMARY_PREF"
echo "[plex-session] primary output: ${STARCH_PRIMARY_OUTPUT:-<any>}"

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------

starch_apply_gpu_env

# Wait for WirePlumber to bind a real default sink (see starch-profile.sh).
starch_wait_for_audio plex-session

# ---------------------------------------------------------------------------
# Launch — gamescope with adaptive sync for judder-free video playback.
# VRR lets gamescope present frames at the content's native cadence
# (24fps, 30fps, etc.) instead of pulling down to a fixed refresh rate.
# On optimus we drop --hdr-enabled: HDR scanout through the Intel display
# pipe isn't supported end-to-end, and Plex will fall back to SDR anyway.
# When Plex exits, gamescope exits, and SDDM takes over.
# ---------------------------------------------------------------------------

GAMESCOPE_ARGS=(--backend drm -f --adaptive-sync)
[ "$STARCH_PROFILE" = "discrete" ] && GAMESCOPE_ARGS+=(--hdr-enabled)
[ -n "${STARCH_PRIMARY_OUTPUT:-}" ] && GAMESCOPE_ARGS+=(--prefer-output "$STARCH_PRIMARY_OUTPUT")

echo "[plex-session] gamescope ${GAMESCOPE_ARGS[*]}"
gamescope "${GAMESCOPE_ARGS[@]}" -- \
    flatpak run --device=dri \
    --env=LIBVA_DRIVER_NAME=nvidia \
    --env=NVD_BACKEND=direct \
    --env=__GLX_VENDOR_LIBRARY_NAME=nvidia \
    --env=GBM_BACKEND=nvidia-drm \
    tv.plex.PlexHTPC

echo "[plex-session] END $(date '+%Y-%m-%d %H:%M:%S')"
