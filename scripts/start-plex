#!/bin/bash
# start-plex — Plex HTPC session via gamescope (adaptive sync for judder-free video)
# Deploy: sudo install -Dm755 scripts/start-plex /usr/local/bin/start-plex
# Log:    ~/.local/share/plex-session.log
set -uo pipefail

# shellcheck source=./starch-profile.sh
. /usr/local/lib/starch/profile.sh

starch_profile_init
starch_session_begin plex
starch_check_gpu_modules plex-session
starch_apply_gpu_env

# Wait for WirePlumber to bind a real default sink (see starch-profile.sh).
starch_wait_for_audio plex-session

# Flatpak sandbox inherits nothing from the host — profile-specific env vars
# must be forwarded explicitly. starch_flatpak_env_args emits the right
# --env=K=V args for the active profile.
mapfile -t FP_ENV < <(starch_flatpak_env_args)

# Launch — gamescope with adaptive sync for judder-free video playback.
# VRR lets gamescope present frames at the content's native cadence
# (24fps, 30fps, etc.) instead of pulling down to a fixed refresh rate.
# HDR scanout is only viable end-to-end on the nvidia profile.
# When Plex exits, gamescope exits, and SDDM takes over.

GAMESCOPE_ARGS=(--backend drm -f --adaptive-sync)
[ "$STARCH_PROFILE" = "nvidia" ] && GAMESCOPE_ARGS+=(--hdr-enabled)
[ -n "${STARCH_PRIMARY_OUTPUT:-}" ] && GAMESCOPE_ARGS+=(--prefer-output "$STARCH_PRIMARY_OUTPUT")

if [ "$STARCH_PROFILE" = "optimus" ]; then
    if [ "${STARCH_OUTPUT_CARD:-}" = "$STARCH_NVIDIA_CARD" ]; then
        GAMESCOPE_ARGS+=(--prefer-vk-device 10de)
    else
        GAMESCOPE_ARGS+=(--prefer-vk-device 8086)
    fi
fi

echo "[plex-session] gamescope ${GAMESCOPE_ARGS[*]}"
exec gamescope "${GAMESCOPE_ARGS[@]}" -- \
    flatpak run --device=dri "${FP_ENV[@]}" tv.plex.PlexHTPC
# Note: on optimus, the PRIME offload vars are already included in FP_ENV
# via starch_flatpak_env_args → starch_prime_env, so the Plex flatpak app
# renders on the NVIDIA dGPU while gamescope scans out on Intel.
